# ═══════════════════════════════════════════════════
# KALYANI PORTFOLIO — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════

# ── MongoDB ──────────────────────────────────────────
# Get from: https://cloud.mongodb.com (Atlas free tier)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=kalyani_portfolio

# ── Auth ─────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-here-change-this
ADMIN_USERNAME=kalyani
# Generate hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ───────────────────────────────────────────
# Get from: https://github.com/settings/tokens (read:user scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=kalyani

# ── Spotify ──────────────────────────────────────────
# Get from: https://developer.spotify.com/dashboard
# Scopes needed: user-read-currently-playing, user-read-recently-played
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# ── Email Notifications ──────────────────────────────
# For contact form email alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password  # Gmail App Password, not your real password
NOTIFY_EMAIL=kalyani@example.com

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://kalyani.dev
